  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-font": "~14.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@react-three/fiber": "^9.6.1",
    "@remotion/cli": "^4.0.464",
    "@remotion/three": "^4.0.464",
    "@types/react": "~19.1.0",
    "remotion": "^4.0.464",
    "three": "^0.184.0",
    "typescript": "~5.9.2"
  },
  "private": true
