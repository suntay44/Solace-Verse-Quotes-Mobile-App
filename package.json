{
  "name": "daily-focus-mobile-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "assets:visuals": "node scripts/generate-visual-assets.mjs",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "remotion:studio": "remotion studio remotion/index.ts",
